"""Environment configuration for development."""

# API Settings
DEBUG=False
PORT=8000
LOG_LEVEL=INFO

# Device Settings (cpu or cuda)
DEVICE=cpu

# Model Settings
USE_SCISPACY=True
USE_BIOBERT=False

# Summarization
SUMMARIZATION_MODEL=google/flan-t5-base

# Database/Storage
STORAGE_PATH=./data/patient_records

# UMLS Settings (optional)
UMLS_API_KEY=

# Rate Limiting
RATE_LIMIT_ENABLED=True
RATE_LIMIT_REQUESTS=100
RATE_LIMIT_WINDOW=60
